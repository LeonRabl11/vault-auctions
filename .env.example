# PostgreSQL (Supabase als reine DB)
# Connection String aus dem Supabase-Dashboard: Project Settings → Database → Connection string
# Empfohlen: Transaction-Pooler (Port 6543) für die App-Laufzeit.
# Format: postgresql://postgres.<project-ref>:<password>@<host>:6543/postgres
DATABASE_URL=

# Better Auth
# Secret zum Signieren von Sessions/Tokens — zufälliger String (>= 32 Zeichen).
# Generieren z. B. mit: npx @better-auth/cli secret   ODER   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Basis-URL der App (lokal):
BETTER_AUTH_URL=http://localhost:3000

# AWS S3 (Bild-Upload via Presigned URLs)
# IAM-User mit s3:PutObject-Rechten auf den Bucket. Bucket muss Bilder
# öffentlich lesbar ausliefern (Bucket-Policy für GetObject).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=

# Cron-Job (finalisiert abgelaufene Auktionen)
# Langer Zufallswert (>= 32 Zeichen), z. B.: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Aufruf: GET /api/cron/finalize mit Header  Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Stripe (Test-Modus) — Keys aus dem Stripe-Dashboard
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook-Secret aus:  stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# Basis-URL für absolute OG-/Canonical-Links (Production-Domain)
NEXT_PUBLIC_SITE_URL=https://vault-auctions-app.vercel.app
