# PostgreSQL (Supabase als reine DB)
# Connection String aus dem Supabase-Dashboard: Project Settings → Database → Connection string
# Empfohlen: Transaction-Pooler (Port 6543) für die App-Laufzeit.
# Format: postgresql://postgres.<project-ref>:<password>@<host>:6543/postgres
DATABASE_URL=

# Better Auth
# Secret zum Signieren von Sessions/Tokens — zufälliger String (>= 32 Zeichen).
# Generieren z. B. mit: npx @better-auth/cli secret   ODER   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Basis-URL der App (lokal):
BETTER_AUTH_URL=http://localhost:3000
